{
    frankenphp {
        num_threads 4
    }

    # Aktifkan admin API (opsional, untuk reload config tanpa restart)
    admin localhost:2019
}

https://localhost {
    root * public/

    # Kompresi response
    encode zstd br gzip

    # Gunakan CA internal Caddy untuk self-signed cert (lokal)
    tls internal

    # PHP server (FrankenPHP)
    php_server

    # Logging error ke file
    log {
        output file writable/logs/caddy_access.log
        format console
    }
}
